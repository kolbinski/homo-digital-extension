{
  "manifest_version": 3,
  "name": "Homo Digital",
  "version": "1.0.0",
  "description": "Career agent panel for managing client job matches, generating tailored CVs, and tracking applications across job boards.",
  "permissions": [
    "sidePanel",
    "activeTab",
    "storage",
    "downloads",
    "scripting",
    "tabs",
    "identity"
  ],
  "host_permissions": [
    "<all_urls>",
    "https://job-matcher-api-production.up.railway.app/*",
    "http://localhost:3000/*"
  ],
  "action": {
    "default_title": "Open Homo Digital"
  },
  "background": {
    "service_worker": "background.js"
  },
  "side_panel": {
    "default_path": "index.html"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content.js"
      ]
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}