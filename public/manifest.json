{
  "manifest_version": 3,
  "name": "Homo Digital",
  "version": "1.0.0",
  "description": "Career agent tool — generate tailored CVs from job offer pages",
  "permissions": ["sidePanel", "activeTab", "storage", "downloads"],
  "host_permissions": [
    "https://job-matcher-api-production.up.railway.app/*",
    "http://localhost:3000/*"
  ],
  "action": {
    "default_title": "Open Homo Digital"
  },
  "background": {
    "service_worker": "background.js"
  },
  "side_panel": {
    "default_path": "index.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
